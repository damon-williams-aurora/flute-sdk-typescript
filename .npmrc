# Pin npm behaviour for reproducible installs across platforms.
#
# `include=optional` ensures that all platform-specific optional binary
# packages (e.g. @rolldown/binding-*, @swc/core-*) and their transitive
# universal deps (e.g. @emnapi/core, @emnapi/runtime) are *fully resolved*
# in package-lock.json — even when generated on a host whose CPU/OS does
# not match a given binding. Without this, `npm ci` fails on CI runners
# with "Missing: @emnapi/core@x.y.z from lock file".
include=optional

# Disable analytics noise; we run with `--no-audit --no-fund` in CI.
fund=false
